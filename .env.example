# DSPyGen Environment Variables
# Copy this file to .env and fill in your values.
# Never commit the real .env file to version control.
#   cp .env.example .env

# ---------------------------------------------------------------------------
# Language Model Providers
# ---------------------------------------------------------------------------

# OpenAI — required for the default gpt-4o / gpt-4o-mini backends
OPENAI_API_KEY=sk-...

# Default model used by init_dspy() when no model argument is supplied.
# Accepts any model name recognised by DSPy, e.g. "gpt-4o", "gpt-4o-mini",
# "groq/llama3-8b-8192", "cerebras/llama3.1-8b", "ollama/llama3".
DSPYGEN_MODEL=gpt-4o

# Ollama — for local inference (no API key required)
# Point this at the Ollama server if it is running on a non-default address.
OLLAMA_HOST=http://localhost:11434

# Groq — high-speed inference for open-weight models
GROQ_API_KEY=gsk_...

# Cerebras — wafer-scale inference
CEREBRAS_API_KEY=...

# ---------------------------------------------------------------------------
# Server Configuration
# ---------------------------------------------------------------------------

# Allowed CORS origins for the MCP SSE transport and any HTTP endpoints.
# Use "*" for development; restrict to specific origins in production.
CORS_ORIGINS=*

# Base URL for the DSPyGen REST API (used by the VS Code extension and CLI).
API_BASE_URL=http://localhost:5555

# MQTT broker for event-driven pipeline triggers.
# Format: host:port  (no scheme prefix)
MQTT_BROKER_URL=localhost:1883

# ---------------------------------------------------------------------------
# Optional / Advanced
# ---------------------------------------------------------------------------

# Log level for the MCP and LSP servers: DEBUG | INFO | WARNING | ERROR
# DSPYGEN_LOG_LEVEL=INFO

# Override the directory scanned for user-defined modules.
# DSPYGEN_MODULE_PATH=/path/to/my/modules

# DSPy request timeout in seconds (default: 60)
# DSPYGEN_TIMEOUT=60

# Maximum tokens passed to the language model by default.
# DSPYGEN_MAX_TOKENS=4096
