{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "DSPyGen DSL",
  "scopeName": "source.dspygen",
  "fileTypes": ["dspy", "dsg"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#booleans" },
    { "include": "#keys" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "name": "comment.line.number-sign.dspygen",
      "match": "#.*$"
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.dspygen",
          "match": "\\b(module|signature|predict|chain_of_thought|retrieve|assert|suggest|program|pipeline|input|output|field|desc|prefix)\\b"
        },
        {
          "name": "keyword.declaration.dspygen",
          "match": "\\b(class|def|import|from|as|return|if|else|elif|for|while|with|try|except|finally|pass|break|continue)\\b"
        },
        {
          "name": "storage.type.dspygen",
          "match": "\\b(str|int|float|bool|list|dict|tuple|set|Any|Optional|Union|List|Dict|Tuple)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.dspygen",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": [{ "include": "#string-escapes" }]
        },
        {
          "name": "string.quoted.single.dspygen",
          "begin": "'''",
          "end": "'''",
          "patterns": [{ "include": "#string-escapes" }]
        },
        {
          "name": "string.quoted.double.dspygen",
          "begin": "\"",
          "end": "\"",
          "patterns": [{ "include": "#string-escapes" }]
        },
        {
          "name": "string.quoted.single.dspygen",
          "begin": "'",
          "end": "'",
          "patterns": [{ "include": "#string-escapes" }]
        }
      ]
    },
    "string-escapes": {
      "name": "constant.character.escape.dspygen",
      "match": "\\\\."
    },
    "numbers": {
      "name": "constant.numeric.dspygen",
      "match": "\\b([0-9]+\\.?[0-9]*)\\b"
    },
    "booleans": {
      "name": "constant.language.dspygen",
      "match": "\\b(true|false|null|True|False|None)\\b"
    },
    "keys": {
      "patterns": [
        {
          "name": "entity.name.tag.dspygen",
          "match": "^\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\s*:"
        },
        {
          "name": "variable.other.dspygen",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=->)"
        },
        {
          "name": "entity.name.function.dspygen",
          "match": "\\b([A-Z][a-zA-Z0-9_]*)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.dspygen",
          "match": "->"
        },
        {
          "name": "keyword.operator.dspygen",
          "match": "[=:,|&!<>+\\-*/%]"
        }
      ]
    }
  }
}
